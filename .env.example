# Database Configuration
DATABASE_URL=postgresql://trader:your_password@localhost:5432/grindstone_apex
DATABASE_ECHO=False

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_TTL=86400

# Exchange API Configuration
EXCHANGE_TYPE=coinbase
EXCHANGE_API_KEY=your_api_key_here
EXCHANGE_SECRET=your_secret_here
EXCHANGE_SANDBOX=True

# Strategy Configuration
BACKTEST_YEAR_RANGE=365
STRATEGY_TEST_TIMEFRAMES=15,60,240
TARGET_WIN_RATE=0.40
TARGET_PROFIT_PCT=0.20
TARGET_SHARPE_RATIO=1.0

# Ralph Loop Configuration
ELITE_THRESHOLD=0.20
MUTATION_RATE=0.15
SECOND_CHANCE_MUTATIONS=5
STRATEGIES_PER_GENERATION=500

# Position Sizing
POSITION_SIZE_TYPE=percent_of_balance
POSITION_SIZE_AMOUNT=0.5
MAX_POSITIONS=1
LEVERAGE=1.0

# Risk Management
STOP_LOSS_ATR_MULTIPLIER=3.5
TAKE_PROFIT_PERCENT=0.20
BREAKEVEN_ON_PROFIT=True
MAX_DRAWDOWN_LIMIT=0.30

# Live Trading
LIVE_TRADING_ENABLED=False
DEPLOY_TOP_N_STRATEGIES=2
PAIRS_TO_TRADE=BTC/USDT,ETH/USDT
TARGET_WEEKLY_PROFIT_USDT=7500
PERFORMANCE_DRIFT_THRESHOLD=0.15

# Telegram
TELEGRAM_BOT_TOKEN=your_token_here
TELEGRAM_CHAT_ID=your_chat_id

# System
LOG_LEVEL=INFO
WORKERS=4
ENV=development
