# ===========================================
# Grindstone Apex Configuration
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ===========================================

# Exchange Configuration
EXCHANGE_TYPE=blofin
BLOFIN_API_KEY=your_api_key_here
BLOFIN_API_SECRET=your_secret_key_here
BLOFIN_PASSPHRASE=your_passphrase_here

# Telegram Bot (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Database
DATABASE_URL=sqlite:///grindstone_apex.db

# Trading Pairs
DEFAULT_PAIRS=BTC/USDT:USDT,ETH/USDT:USDT,XAU/USDT:USDT,XAG/USDT:USDT
DEFAULT_TIMEFRAME=15m

# Ralph Loop Configuration
ELITE_THRESHOLD=0.20
MUTATION_RATE=0.15
STRATEGIES_PER_GENERATION=500

# Auto-Deploy (set to true once you trust the system)
AUTO_DEPLOY_ENABLED=false
AUTO_DEPLOY_THRESHOLD=85

# Risk Management
STOP_LOSS_ATR_MULTIPLIER=3.5
TAKE_PROFIT_PERCENT=0.20
MAX_DRAWDOWN_LIMIT=0.30

# Position Sizing
POSITION_SIZE_TYPE=percent_of_balance
POSITION_SIZE_AMOUNT=0.5
MAX_POSITIONS=1
LEVERAGE=1.0

# System
LOG_LEVEL=INFO
